PORT=5000
NODE_ENV=development

# JWT CONFIGURATION
JWT_SECRET=rentgb_super_secret_jwt_signature_key_2026
JWT_EXPIRES_IN=7d

# DATABASE CONFIGURATION
# DB_MODE can be: 'postgres' or 'json' (json mode is a high-fidelity mock database that runs out of the box)
DB_MODE=json

# PostgreSQL neon connection details (if using postgres mode)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rentgb
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rentgb
